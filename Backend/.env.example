# Copy to .env and adjust values for local development.
# cp .env.example .env

# --- App ---
APP_NAME=Sneaker Recommendation API
APP_VERSION=0.1.0
DEBUG=true

# Comma-separated browser origins allowed to call the API
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Database (Neon in production; local Postgres optional) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sneakers

# --- Cloudinary (Phase 3 pipeline) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Search provider (Phase 3 pipeline) ---
SEARCH_PROVIDER=serpapi
SERPAPI_KEY=

# --- ML (Phase 4+) ---
ENABLE_ST_RERANK=false
MODEL_PATH=ml/artifacts/model.pkl

# --- API docs ---
ENABLE_DOCS=true
